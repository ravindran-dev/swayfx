### LID SWITCH
# Deliberately NOT a real suspend - see the comment in lid-close.sh for why
# (boot disk is an external USB SSD; a real suspend hung 11+ minutes on a
# previous boot trying to resume it). logind's own HandleLidSwitch is set
# to "ignore" so sway has sole control here - see the lid-fix script.
# --reload: re-applies correctly if sway reloads while the lid is already
# closed, instead of leaving the screen in a stale on/off state.
bindswitch --reload lid:on exec /home/ravi/.config/sway/lid-close.sh
bindswitch --reload lid:off exec swaymsg 'output * power on'

