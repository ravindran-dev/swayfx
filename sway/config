### AUTOSTART
exec_always systemctl --user set-environment XDG_CURRENT_DESKTOP=sway XDG_SESSION_TYPE=wayland QT_QPA_PLATFORM=wayland BROWSER=firefox
exec_always systemctl --user import-environment DISPLAY WAYLAND_DISPLAY SWAYSOCK
exec_always dbus-update-activation-environment --systemd DISPLAY WAYLAND_DISPLAY SWAYSOCK XDG_CURRENT_DESKTOP=sway XDG_SESSION_TYPE=wayland QT_QPA_PLATFORM=wayland BROWSER=firefox
exec_always sh -c 'pkill -x waybar || true; exec waybar -c /home/ravi/.config/waybar/config -s /home/ravi/.config/waybar/style.css'
exec mako
# nm-applet removed: waybar's network module + network-popup.sh + right-click
# nm-connection-editor cover it, and no VPN profiles exist. Saved ~48 MB RSS.
# Restore with: exec nm-applet
exec wl-paste --type text --watch cliphist store
exec_always sh -c 'pkill -x swayidle || true; exec /home/ravi/.config/sway/idle.sh'
# wob: the volume OSD bar (see AUDIO section below) - pkill+restart on
# reload rather than plain exec, same reasoning as waybar above, so a
# `$mod+Shift+c` reload doesn't leave a second wob reading the same FIFO.
# `pkill -x`, NOT `-f`: confirmed live, isolating it line by line, that
# `pkill -f <anything>` inside this exec_always never returns at all (not
# even a nonexistent pattern that should exit instantly) - silently
# blocking every command after it in the same sh -c, which is why this
# whole line was never actually starting wob in the first place. `-x`
# (exact process-name match, no full-cmdline /proc scan) doesn't hit
# whatever that was and returns immediately, confirmed the same way.
exec_always sh -c 'pkill -x wob-daemon.sh || true; pkill -x wob || true; exec /home/ravi/.config/sway/wob-daemon.sh'

