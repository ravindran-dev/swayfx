### FLOATING
bindsym $mod+Shift+space floating toggle
floating_modifier $mod normal
# wofi launcher (layer-shell, location=center) is unaffected by for_window;
# this rule only positions --normal-window wofi instances (waybar popups).
# Initial placement only - network-popup.sh's reposition_once() corrects the
# final resting position once wofi's real content size is known. Must be
# "move absolute position", not plain "move position": plain position is
# relative to the workspace's usable area (inset by gaps + the bar's
# reserved exclusive zone), which silently offsets floating windows by
# ~(+22,+64) here - "absolute" places them at the true screen origin.
for_window [app_id="wofi"] floating enable, border pixel 0, sticky enable, move absolute position 1538 48

# waybar on-click windows: float them under the modules instead of tiling
for_window [app_id="kitty" title="btop"] floating enable, resize set 1100 700, move position center
for_window [app_id="kitty" title="Calendar"] floating enable, resize set 520 400, move absolute position 1390 48

# Rootlink draws its own rounded window chrome and shadow (Finder-style
# floating window); a sway-drawn border/titlebar on top of that reads as a
# double outline, so this strips sway's own decoration and lets the app's
# QML chrome be the only frame.
for_window [app_id="rootlink"] floating enable, border pixel 0, move position center


### AUDIO
# Each binding still does the real pactl change, then feeds the resulting
# level to wob's FIFO for the on-screen bar (volume-osd.sh reads it back
# from pactl rather than assuming the delta applied cleanly, since it's
# already clamped at 0/100 either way).
bindsym XF86AudioRaiseVolume exec pactl set-sink-volume @DEFAULT_SINK@ +5% && /home/ravi/.config/sway/volume-osd.sh
bindsym XF86AudioLowerVolume exec pactl set-sink-volume @DEFAULT_SINK@ -5% && /home/ravi/.config/sway/volume-osd.sh
bindsym XF86AudioMute exec pactl set-sink-mute @DEFAULT_SINK@ toggle && /home/ravi/.config/sway/volume-osd.sh

### BRIGHTNESS
bindsym XF86MonBrightnessUp exec brightnessctl set +5%
bindsym XF86MonBrightnessDown exec brightnessctl set 5%-

