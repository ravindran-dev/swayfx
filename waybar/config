{
  "layer": "top",
  "position": "top",
  "height": 34,
  "spacing": 8,
  "margin-top": 8,
  "margin-left": 10,
  "margin-right": 10,
  "modules-left": ["sway/workspaces", "custom/media"],
  "modules-center": ["sway/window"],
  "modules-right": ["tray", "pulseaudio", "network", "bluetooth", "cpu", "memory", "battery", "clock"],

  "sway/workspaces": {
    "disable-scroll": true,
    "all-outputs": true,
    "format": "{name}",
    "persistent_workspaces": {
      "1": [],
      "2": [],
      "3": [],
      "4": [],
      "5": []
    }
  },

  "sway/window": {
    "format": "{title}",
    "max-length": 45,
    "tooltip": false
  },

  "custom/media": {
    "exec": "python3 /home/ravi/.config/waybar/scripts/media-visualizer.py",
    "return-type": "json",
    "escape": true,
    "on-click": "sh /home/ravi/.config/waybar/scripts/media-focus-window.sh",
    "on-click-middle": "playerctl play-pause",
    "on-click-right": "playerctl next",
    "on-scroll-down": "playerctl previous",
    "tooltip": true
  },

  "tray": {
    "spacing": 10
  },

  "pulseaudio": {
    "format": "{icon} {volume}%",
    "format-muted": "蟀潫 muted",
    "format-icons": {
      "default": ["蟀暱", "蟀杸", "蟀暰"]
    },
    "on-click": "python3 /home/ravi/.config/waybar/volume-popup/volume_popup.py",
    "on-click-right": "pavucontrol"
  },

  "network": {
    "format-wifi": "蟀柀 {essid} {signalStrength}%",
    "format-ethernet": "蟀垁 connected",
    "format-disconnected": "蟀柂 offline",
    "tooltip-format-wifi": "{ifname} 路 {ipaddr}",
    "tooltip-format-ethernet": "{ifname} 路 {ipaddr}",
    "on-click": "python3 /home/ravi/.config/waybar/wifi-popup/wifi_popup.py",
    "on-click-right": "nm-connection-editor"
  },

  "bluetooth": {
    "format": "蟀偗 {status}",
    "format-connected": "蟀偙 {device_alias}",
    "format-disabled": "蟀偛 off",
    "format-off": "蟀偛 off",
    "tooltip-format": "{controller_alias}\t{controller_address}",
    "tooltip-format-connected": "{controller_alias}\t{controller_address}\n\nConnected: {device_enumerate}",
    "tooltip-format-enumerate-connected": "{device_alias}\t{device_address}",
    "on-click": "python3 /home/ravi/.config/waybar/bluetooth-popup/bluetooth_popup.py",
    "on-click-right": "bluetoothctl power toggle"
  },

  "cpu": {
    "format": "蟀崨 {usage}%",
    "tooltip-format": "CPU {usage}% 路 click for btop",
    "on-click": "kitty --title btop -e btop"
  },

  "memory": {
    "format": "蟀槡 {percentage}%",
    "tooltip-format": "Memory {used:0.1f}G / {total:0.1f}G 路 click for btop",
    "on-click": "kitty --title btop -e btop"
  },

  "battery": {
    "bat": "BAT0",
    "adapter": "ADP1",
    "interval": 30,
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format": "{icon} {capacity}%",
    "format-charging": "蟀倓 {capacity}%",
    "format-plugged": "蟀殽 {capacity}%",
    "format-full": "蟀伖 {capacity}%",
    "format-icons": ["蟀値", "蟀伜", "蟀伡", "蟀伨", "蟀個", "蟀伖"],
    "tooltip-format": "{timeTo} 路 {capacity}%"
  },

  "clock": {
    "format": "蟀 {:%a %d %b  %H:%M}",
    "tooltip-format": "<big>{:%A, %d %B %Y}</big>\n<tt>{calendar}</tt>",
    "on-click": "kitty --title Calendar -e sh -c 'cal -3; printf \"\\nPress Enter to close\"; read _'",
    "calendar": {
      "mode": "month",
      "mode-mon-col": 3,
      "weeks-pos": "right",
      "on-scroll": 1
    }
  }
}
