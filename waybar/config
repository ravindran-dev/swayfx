{
  "layer": "top",
  "position": "top",
  "height": 34,
  "spacing": 8,
  "margin-top": 8,
  "margin-left": 10,
  "margin-right": 10,
  "modules-left": ["sway/workspaces", "custom/media"],
  "modules-center": ["sway/window"],
  "modules-right": ["tray", "pulseaudio", "network", "bluetooth", "cpu", "memory", "battery", "clock"],

  "sway/workspaces": {
    "disable-scroll": true,
    "all-outputs": true,
    "format": "{name}"
  },

  "sway/window": {
    "format": "{title}",
    "max-length": 45,
    "tooltip": false
  },

  "custom/media": {
    "exec": "python3 /home/ravi/.config/waybar/scripts/media-visualizer.py",
    "return-type": "json",
    "escape": true,
    "on-click": "sh /home/ravi/.config/waybar/scripts/media-focus-window.sh",
    "on-click-middle": "playerctl play-pause",
    "on-click-right": "playerctl next",
    "on-scroll-down": "playerctl previous",
    "tooltip": true
  },

  "tray": {
    "spacing": 10
  },

  "pulseaudio": {
    "format": "{icon} {volume}%",
    "format-muted": "σΑùü muted",
    "format-icons": {
      "default": ["σΑïΩ", "σΑ•Ä", "σΑïΨ"]
    },
    "on-click": "python3 /home/ravi/.config/waybar/volume-popup/volume_popup.py",
    "on-click-right": "pavucontrol"
  },

  "network": {
    "format-wifi": "σΑ•© {essid} {signalStrength}%",
    "format-ethernet": "σΑàÄ connected",
    "format-disconnected": "σΑ•Σ offline",
    "tooltip-format-wifi": "{ifname} ¬Ζ {ipaddr}",
    "tooltip-format-ethernet": "{ifname} ¬Ζ {ipaddr}",
    "on-click": "python3 /home/ravi/.config/waybar/wifi-popup/wifi_popup.py",
    "on-click-right": "nm-connection-editor"
  },

  "bluetooth": {
    "format": "σΑ²· {status}",
    "format-connected": "σΑ²± {device_alias}",
    "format-disabled": "σΑ²≤ off",
    "format-off": "σΑ²≤ off",
    "tooltip-format": "{controller_alias}\t{controller_address}",
    "tooltip-format-connected": "{controller_alias}\t{controller_address}\n\nConnected: {device_enumerate}",
    "tooltip-format-enumerate-connected": "{device_alias}\t{device_address}",
    "on-click": "python3 /home/ravi/.config/waybar/bluetooth-popup/bluetooth_popup.py",
    "on-click-right": "bluetoothctl power toggle"
  },

  "cpu": {
    "format": "σΑç¦ {usage}%",
    "tooltip-format": "CPU {usage}% ¬Ζ click for btop",
    "on-click": "kitty --title btop -e btop"
  },

  "memory": {
    "format": "σΑ‰ö {percentage}%",
    "tooltip-format": "Memory {used:0.1f}G / {total:0.1f}G ¬Ζ click for btop",
    "on-click": "kitty --title btop -e btop"
  },

  "battery": {
    "bat": "BAT0",
    "adapter": "ADP1",
    "interval": 30,
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format": "{icon} {capacity}%",
    "format-charging": "σΑ²³ {capacity}%",
    "format-plugged": "σΑöΞ {capacity}%",
    "format-full": "σΑ¹Ι {capacity}%",
    "format-icons": ["σΑ²é", "σΑ¹Κ", "σΑ¹Φ", "σΑ¹Ψ", "σΑ²Ä", "σΑ¹Ι"],
    "tooltip-format": "{timeTo} ¬Ζ {capacity}%"
  },

  "clock": {
    "format": "σΑΞî {:%a %d %b  %H:%M}",
    "tooltip-format": "<big>{:%A, %d %B %Y}</big>\n<tt>{calendar}</tt>",
    "on-click": "kitty --title Calendar -e sh -c 'cal -3; printf \"\\nPress Enter to close\"; read _'",
    "calendar": {
      "mode": "month",
      "mode-mon-col": 3,
      "weeks-pos": "right",
      "on-scroll": 1
    }
  }
}
